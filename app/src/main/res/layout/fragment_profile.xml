<?xml version="1.0" encoding="utf-8"?>
<!-- User profile screen displaying account information, application details, and logout options. -->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    tools:context=".ui.fragments.ProfileFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Navigation header -->
        <ImageButton
            android:id="@+id/btn_back_profile"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:src="@drawable/ic_back"
            app:tint="@color/bold_text_color" />

        <!-- User account information section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤 Profile"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/bold_text_color"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/profile_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Diana"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/bold_text_color" />

                <TextView
                    android:id="@+id/profile_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    tools:text="Email: diana@gmail.com"
                    android:textSize="14sp"
                    android:textColor="@color/input_box_tint" />


            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- User feedback section -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_send_feedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="✉️ Send Feedback"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/bold_text_color" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_back"
                    android:rotation="180"
                    app:tint="@color/placeholder_text_color" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Application information section -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ℹ️ About"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/bold_text_color"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Version 1.0"
                    android:textColor="@color/input_box_tint"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Created by Diana Dimla"
                    android:textColor="@color/input_box_tint"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Walo – Student Finance Helper"
                    android:textColor="@color/input_box_tint"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Helping students manage smarter 💸"
                    android:textColor="@color/input_box_tint" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Account session management -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/logoutButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:paddingVertical="12dp"
            android:text="Logout"
            app:backgroundTint="@color/bold_text_color"
            android:textColor="@android:color/white"
            app:cornerRadius="16dp"
            app:elevation="4dp"/>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
