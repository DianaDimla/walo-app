<?xml version="1.0" encoding="utf-8"?>
<!-- Dialog for configuring and creating a new budget pod. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Pod identification input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/pod_name_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/pod_name_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Pod Name (e.g., Food, Travel)" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Budget limit configuration -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/pod_limit_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/pod_limit_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Set Budget Limit (€)"
            android:inputType="numberDecimal" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- Icon selection section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Choose an Icon"
        android:textSize="16sp" />

    <!-- Grid of available category emojis -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/emoji_recycler_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:maxHeight="200dp" />

</LinearLayout>
