<?xml version="1.0" encoding="utf-8"?>
<!-- Screen for managing financial transactions and budget pods. -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <!-- Overall budget summary display -->
    <TextView
        android:id="@+id/amount_display"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="€0.00"
        android:textColor="@color/input_box_tint"
        android:textSize="48sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Quick action buttons for logging financial entries -->
    <Button
        android:id="@+id/btn_save_expense"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:text="-"
        android:textSize="24sp"
        app:layout_constraintEnd_toStartOf="@+id/btn_save_income"
        app:layout_constraintHorizontal_chainStyle="spread"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/amount_display" />

    <Button
        android:id="@+id/btn_save_income"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:text="+"
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/btn_save_expense"
        app:layout_constraintTop_toTopOf="@+id/btn_save_expense" />

    <!-- Pods management section -->
    <TextView
        android:id="@+id/pods_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pods"
        android:textColor="@color/bold_text_color"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toBottomOf="@+id/btn_save_expense"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/btn_edit_pod"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Edit"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/pods_title"
        app:layout_constraintBottom_toBottomOf="@+id/pods_title"/>

    <Button
        android:id="@+id/btn_add_pod"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add"
        android:layout_marginEnd="8dp"
        android:textSize="12sp"
        app:layout_constraintEnd_toStartOf="@+id/btn_edit_pod"
        app:layout_constraintTop_toTopOf="@+id/pods_title"
        app:layout_constraintBottom_toBottomOf="@+id/pods_title"/>

    <!-- Grid display of active budget pods -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/pods_recycler_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:spanCount="2"
        app:layout_constraintTop_toBottomOf="@+id/pods_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/history_container"
        app:layout_constraintVertical_weight="1"
        tools:listitem="@layout/item_pod"
        tools:itemCount="4" />

    <!-- Chronological transaction history section -->
    <LinearLayout
        android:id="@+id/history_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@drawable/bg_expense_history"
        app:layout_constraintTop_toBottomOf="@+id/pods_recycler_view"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_weight="1.2">

        <TextView
            android:id="@+id/history_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Expense History"
            android:textColor="@color/bold_text_color"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/expense_history_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_transaction"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>