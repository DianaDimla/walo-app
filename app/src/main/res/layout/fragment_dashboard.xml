<?xml version="1.0" encoding="utf-8"?>
<!-- Main dashboard interface providing a high-level overview of the user's financial status. -->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:clipToPadding="false"
    android:paddingBottom="88dp"
    tools:context=".ui.fragments.DashboardFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Navigation and system interaction icons -->
        <ImageView
            android:id="@+id/profile_icon"
            android:layout_width="40dp"
            android:layout_height="52dp"
            android:src="@drawable/ic_profile"
            android:contentDescription="Profile Settings"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/notification_bell"
            android:layout_width="40dp"
            android:layout_height="52dp"
            android:layout_marginEnd="8dp"
            android:contentDescription="AI Nudge History"
            android:padding="6dp"
            android:src="@drawable/notification"
            app:layout_constraintEnd_toStartOf="@id/trophy_icon"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/trophy_icon"
            android:layout_width="50dp"
            android:layout_height="55dp"
            android:contentDescription="Achievements"
            android:padding="9dp"
            android:src="@drawable/trophy"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Gamification streak visual indicator -->
        <FrameLayout
            android:id="@+id/streak_container"
            android:layout_width="120dp"
            android:layout_height="150dp"
            android:layout_marginEnd="-30dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/walo_mascot"
            app:layout_constraintEnd_toStartOf="@id/walo_mascot"
            app:layout_constraintTop_toTopOf="@id/walo_mascot">

            <ImageView
                android:id="@+id/seaweed_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/seaweed_icon"
                android:scaleType="centerInside" />

            <TextView
                android:id="@+id/streak_number_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:text="0"
                android:textColor="@color/bold_text_color"
                android:textSize="24sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- Brand mascot and personalised greeting -->
        <ImageView
            android:id="@+id/walo_mascot"
            android:layout_width="193dp"
            android:layout_height="174dp"
            android:contentDescription="Walo Mascot"
            android:src="@drawable/walobluebg"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/greeting_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Hi _____ , here’s your budget summary!"
            android:textColor="@color/bold_text_color"
            android:textSize="18sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/walo_mascot" />

        <!-- Cumulative budget overview with quick transaction actions -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/budget_summary_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/nav_bar_blue"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/greeting_text">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <TextView
                    android:id="@+id/summary_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total Budget"
                    android:textColor="@color/bold_text_color"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/dashboard_amount_display"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="€0.00"
                    android:textColor="@color/input_box_tint"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toStartOf="@+id/btn_save_expense_dashboard"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/summary_title" />

                <Button
                    android:id="@+id/btn_save_expense_dashboard"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_marginEnd="12dp"
                    android:text="-"
                    android:textSize="24sp"
                    app:layout_constraintBottom_toBottomOf="@+id/dashboard_amount_display"
                    app:layout_constraintEnd_toStartOf="@+id/btn_save_income_dashboard"
                    app:layout_constraintTop_toTopOf="@+id/dashboard_amount_display" />

                <Button
                    android:id="@+id/btn_save_income_dashboard"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:text="+"
                    android:textSize="24sp"
                    app:layout_constraintBottom_toBottomOf="@+id/dashboard_amount_display"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/dashboard_amount_display" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Visual categorical spending distribution -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/spending_breakdown_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/budget_summary_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="Spending Breakdown"
                    android:textColor="@color/bold_text_color"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:layout_marginTop="8dp">

                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/spending_pie_chart"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/empty_state_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="No spending data for this month yet"
                        android:textColor="@color/bold_text_color"
                        android:visibility="visible" />
                </FrameLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Chronological record of recent financial activity -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/recent_transactions_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/pastel_yellow"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/spending_breakdown_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:text="Recent Transactions"
                    android:textColor="@color/bold_text_color"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recent_transactions_recycler_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    tools:listitem="@layout/item_transaction" />

                <Button
                    android:id="@+id/btn_view_all_transactions"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="View All"
                    android:textColor="@color/bold_text_color" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
